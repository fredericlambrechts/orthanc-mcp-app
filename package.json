{
  "name": "orthanc-mcp-app",
  "version": "0.1.0",
  "description": "Claude MCP App that embeds the OHIF DICOM viewer inline in chat. Open any DICOMweb study by pasting a link. For demonstration, education, and non-diagnostic use only.",
  "type": "module",
  "license": "MIT",
  "author": "Frederic Lambrechts",
  "homepage": "https://github.com/fredericlambrechts/orthanc-mcp-app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredericlambrechts/orthanc-mcp-app.git"
  },
  "bugs": {
    "url": "https://github.com/fredericlambrechts/orthanc-mcp-app/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run build:ui",
    "build:ui": "vite build --config ui/vite.config.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^2.1.0"
  }
}
